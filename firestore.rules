rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuarios: cada quien solo puede ver y editar su propio perfil
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Productos: lectura pública, escritura solo para admins
    match /products/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Pedidos: cualquiera puede crear (checkout), solo admins pueden leer/actualizar
    match /orders/{orderId} {
      allow create: if true;
      allow read, update: if request.auth != null;
    }

    // Config del sitio: lectura pública, escritura solo para autenticados
    match /site_config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Contadores: lectura pública (checkout necesita leer), escritura solo autenticados
    match /counters/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Clientes CRM: solo admins (usuarios autenticados)
    match /customers/{customerId} {
      allow read, write: if request.auth != null;
    }

    // Movimientos de inventario: solo admins (usuarios autenticados)
    match /inventory_movements/{movementId} {
      allow read, write: if request.auth != null;
    }
  }
}
